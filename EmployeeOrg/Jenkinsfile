pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Prepare') {
            steps {
                sh 'chmod +x EmployeeOrg/mvnw'
            }
        }

        stage('Build') {
            steps {
                dir('EmployeeOrg') {
                    sh './mvnw clean compile'
                }
            }
        }

        stage('Test') {
            steps {
                dir('EmployeeOrg') {
                    sh './mvnw test'
                }
            }
        }

        stage('Package') {
            steps {
                dir('EmployeeOrg') {
                    sh './mvnw package'
                }
            }
        }
    }

    post {
        success {
            echo 'Build completed successfully!'
        }

        failure {
            echo 'Build failed.'
        }
    }
}
